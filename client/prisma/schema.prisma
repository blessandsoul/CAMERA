generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String   @id
  slug            String   @unique
  categories      Json
  price           Float
  originalPrice   Float?
  currency        String   @default("GEL")
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  images          Json
  nameKa          String   @db.VarChar(500)
  nameRu          String   @db.VarChar(500)
  nameEn          String   @db.VarChar(500)
  descriptionKa   String?  @db.Text
  descriptionRu   String?  @db.Text
  descriptionEn   String?  @db.Text
  content         String?  @db.LongText
  relatedProducts Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  specs ProductSpec[]

  @@index([isActive])
  @@index([isFeatured])
  @@map("products")
}

model ProductSpec {
  id        String @id @default(uuid())
  productId String
  keyKa     String @db.VarChar(200)
  keyRu     String @db.VarChar(200)
  keyEn     String @db.VarChar(200)
  value     String @db.VarChar(500)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([keyKa, value])
  @@map("product_specs")
}

model Article {
  id          String   @id
  slug        String   @unique
  title       String   @db.VarChar(500)
  excerpt     String   @db.Text
  category    String
  coverImage  String   @default("")
  isPublished Boolean  @default(false)
  readMin     Int      @default(5)
  content     String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
  @@map("articles")
}

model Order {
  id        String   @id
  name      String   @db.VarChar(200)
  phone     String   @db.VarChar(50)
  locale    String   @db.VarChar(5)
  total     Float
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  name     String @db.VarChar(500)
  quantity Int
  price    Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model Inquiry {
  id        String   @id
  name      String   @db.VarChar(200)
  phone     String   @db.VarChar(50)
  message   String   @db.Text
  locale    String   @db.VarChar(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("inquiries")
}

model Project {
  id         String   @id
  titleKa    String   @db.VarChar(300)
  titleRu    String   @db.VarChar(300)
  titleEn    String   @db.VarChar(300)
  locationKa String   @db.VarChar(300)
  locationRu String   @db.VarChar(300)
  locationEn String   @db.VarChar(300)
  type       String
  cameras    Int      @default(0)
  image      String   @default("")
  year       String   @db.VarChar(10)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@map("projects")
}

model CatalogConfig {
  id         String   @id @default("singleton")
  categories Json
  filters    Json
  updatedAt  DateTime @updatedAt

  @@map("catalog_config")
}

model SiteSettings {
  id           String   @id @default("singleton")
  contact      Json
  business     Json
  hours        Json
  stats        Json
  social       Json
  announcement Json
  updatedAt    DateTime @updatedAt

  @@map("site_settings")
}
